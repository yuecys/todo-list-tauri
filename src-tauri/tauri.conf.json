{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Todo",
  "version": "1.0.0",
  "identifier": "com.todolist.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Todo",
        "width": 390,
        "height": 790,
        "minWidth": 390,
        "maxWidth": 390,
        "minHeight": 64,
        "maxHeight": 790,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
